{
    "schemaVersion": 1,
    "id": "legacy-packs",
    "version": "${version}",
    "name": "Legacy Packs",
    "description": "Automatically translates old resource pack file paths to modern format, making 1.7/1.8 era packs work on modern Minecraft.",
    "authors": ["LegacyPacks"],
    "contact": {},
    "license": "MIT",
    "icon": "assets/legacy-packs/icon.png",
    "environment": "client",
    "entrypoints": {
        "client": [
            "com.legacypacks.LegacyPacksMod"
        ]
    },
    "mixins": [
        "legacy-packs.mixins.json"
    ],
    "depends": {
        "fabricloader": ">=0.18.1",
        "minecraft": "~1.21",
        "java": ">=21",
        "fabric-api": "*"
    }
}
